# ─── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://refiqo:refiqo@localhost:5432/refiqo?schema=public"

# ─── Auth / JWT ────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_ACCESS_TTL=900            # 15 minutes (seconds)
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_TTL=2592000       # 30 days (seconds)

# ─── Adapters (local | cloud) ───────────────────────────────────────────────
ADAPTER_MODE=local
LOCAL_STORAGE_DIR=./storage
PUBLIC_BASE_URL=http://localhost:4000

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# ─── Rate limiting ──────────────────────────────────────────────────────────
THROTTLE_TTL=10               # seconds
THROTTLE_LIMIT=10             # requests per TTL

# ─── Cloud providers (only required when ADAPTER_MODE=cloud) ─────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=refiqo
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
GOOGLE_OAUTH_CLIENT_ID=
LINKEDIN_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_ID=
