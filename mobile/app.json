{
  "expo": {
    "name": "Refiqo",
    "slug": "refiqo",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "refiqo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B0B12"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.refiqo.app"
    },
    "android": {
      "package": "com.refiqo.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0B12"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "apiBaseUrl": "http://192.168.1.4:4000/api/v1"
    }
  }
}
